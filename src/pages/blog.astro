---
import Layout from "../layouts/Layout.astro";
import { SITE_URL, SITE_NAME, POSTS } from "../data/site";

const title = `Writing — ${SITE_NAME}`;
const description = "Notes on design, code and craft, published on Medium.";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: SITE_URL },
      { "@type": "ListItem", position: 2, name: "Blog", item: `${SITE_URL}/blog` },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    itemListElement: POSTS.map((post, i) => ({
      "@type": "ListItem",
      position: i + 1,
      url: post.url,
      item: {
        "@type": "BlogPosting",
        headline: post.title,
        description: post.subtitle,
        datePublished: new Date(post.published_date).toISOString().slice(0, 10),
        url: post.url,
        author: { "@type": "Person", name: SITE_NAME },
      },
    })),
  },
];
---

<Layout title={title} description={description} path="/blog" jsonLd={jsonLd}>
  <div class="pf-page">
    <h1 class="pf-eyebrow pf-fade">Writing</h1>
    <div class="pf-posts">
      {POSTS.map((post) => (
        <a href={post.url} target="_blank" rel="noopener" class="pf-post">
          <div>
            <p class="pf-meta pf-post-meta">{post.published_date}</p>
            <h2 class="pf-post-title">{post.title}</h2>
            <p class="pf-post-excerpt">{post.subtitle}</p>
          </div>
          <span class="pf-post-read">{post.article_length}</span>
        </a>
      ))}
    </div>
  </div>
</Layout>

<style>
  .pf-posts { margin-top: 64px; border-top: 1px solid #0b0b0b; }
  .pf-post {
    width: 100%;
    text-align: left;
    text-decoration: none;
    color: inherit;
    background: none;
    padding: 32px 4px;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 24px;
    align-items: start;
    border-bottom: 1px solid #ececec;
    transition: padding-left .25s;
  }
  .pf-post:hover { padding-left: 14px; }
  .pf-post-meta { margin: 0 0 12px; font-size: 11px; }
  .pf-post-title {
    margin: 0;
    font-family: 'Newsreader', serif;
    font-weight: 400;
    font-size: clamp(24px, 3vw, 34px);
    letter-spacing: -0.01em;
  }
  .pf-post-excerpt { margin: 12px 0 0; font-size: 16px; line-height: 1.6; color: #3a3a3a; max-width: 60ch; }
  .pf-post-read {
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    color: #8a8a8a;
    white-space: nowrap;
    padding-top: 26px;
  }
</style>
