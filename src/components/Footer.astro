---
import { SITE_NAME } from "../data/site";
const year = new Date().getFullYear();
---

<footer class="pf-footer">
  <div class="pf-footer-inner">
    <span>© {year} {SITE_NAME}</span>
    <span>Designed &amp; built in the browser</span>
  </div>
</footer>

<style>
  .pf-footer { border-top: 1px solid #ececec; margin-top: 40px; }
  .pf-footer-inner {
    max-width: 1120px;
    margin: 0 auto;
    padding: 28px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #8a8a8a;
  }
</style>
