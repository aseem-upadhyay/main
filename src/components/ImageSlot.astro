---
interface Props {
  placeholder: string;
  style?: string;
}

const { placeholder, style } = Astro.props;
---

<div class="image-slot" style={style} role="img" aria-label={placeholder}>
  <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
    <rect x="3" y="3" width="18" height="18" rx="2"></rect>
    <circle cx="8.5" cy="8.5" r="1.5"></circle>
    <path d="m21 15-5-5L5 21"></path>
  </svg>
  <span class="image-slot-label">{placeholder}</span>
</div>

<style>
  .image-slot {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: rgba(11,11,11,0.03);
    border: 1.5px dashed rgba(11,11,11,0.2);
    border-radius: 6px;
    color: rgba(11,11,11,0.35);
  }
  .image-slot-label {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
</style>
